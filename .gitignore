# ---- Godot 4 ----
# Import cache + engine-generated metadata. Must be ignored.
.godot/
/android/

# Legacy import folder (Godot 3) — harmless to keep listed
.import/

# Generated export config (can contain local paths / keystore passwords)
export.cfg
export_presets.cfg

# Auto-generated translation binaries
*.translation

# Mono / C# (only matters if you ever use the .NET version)
.mono/
data_*/
mono_crash.*.json

# ---- OS / editor junk ----
.DS_Store
Thumbs.db
desktop.ini
*.swp
.idea/
.vscode/

# ---- Build / export output ----
/build/
/export/
*.exe
*.pck
*.zip
